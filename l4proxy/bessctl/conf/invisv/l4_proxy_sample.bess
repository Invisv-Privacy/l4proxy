# Dummy INVISV L4 proxy example with TCP/UDP traffic

import scapy.all as scapy
import socket

num_cores = int($BESS_CORES!"4")

# Craft a packet with the specified IP addresses
def gen_packet(proto, src_ip, dst_ip):
    eth = scapy.Ether(src='02:1e:67:9f:4d:ae', dst='06:16:3e:1b:72:32')
    ip = scapy.IP(src=src_ip, dst=dst_ip)
    l4 = proto(sport=10001, dport=12345)
    payload = 'helloworld'
    pkt = eth/ip/l4/payload
    return bytes(pkt)

packets = [gen_packet(scapy.UDP, '172.16.100.1', '127.0.0.1'), # allow
           gen_packet(scapy.UDP, '172.12.55.99', '127.0.0.1'), # deny
           gen_packet(scapy.UDP, '172.12.55.99', '127.0.0.1'),
           gen_packet(scapy.UDP, '172.16.100.1', '127.0.0.1'),
           gen_packet(scapy.UDP, '192.168.1.123', '127.0.0.1'), # allow
           gen_packet(scapy.TCP, '192.168.1.123', '127.0.0.1'), # allow
           ]

# INVISV L4 proxy configuration
l4proxy::INVISVL4Proxy(l4_port_timeout_ms=60000,
    l4_port_ranges=[{'begin': 1, 'end': 5000, 'suspended': False}])
l4proxy.set_proxy(proxy_addr='127.0.0.1',
    proxy_tcp_port=12345, proxy_udp_port=12345)
l4proxy.set_next_hop_endpoint(next_hop_addr='172.217.12.238',
    next_hop_tcp_port=443, next_hop_udp_port=443)
l4proxy.set_client_allowlist(client_addr='172.16.100.1', add=True)
l4proxy.set_client_allowlist(client_addr='172.12.55.99', add=False)
l4proxy.set_client_allowlist(client_addr='192.168.1.123', add=True)

# Cores have to be added before WorkerSplit is created
for i in range(num_cores):
    bess.add_worker(i, i)

source = {}
for i in range(num_cores):
    source[i] = Source()
    source[i] -> Rewrite(templates=packets) -> l4proxy

# Split workers for downstream modules
l4proxy -> ws::WorkerSplit()
for i in range(num_cores):
    ws:i -> MACSwap() -> Sink()
    source[i].attach_task(wid=i)
